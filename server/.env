PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/certificate_verification
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRES_IN=1d
BASE_URL=http://localhost:5000

# One-time first admin setup
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_BOOTSTRAP_SECRET=replace_with_long_random_bootstrap_secret

# Legacy admin seeding (dev-only)
ALLOW_INSECURE_ADMIN_SEED=false
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Optional blockchain integration (Ethereum-compatible RPC)
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_CONTRACT_ADDRESS=
BLOCKCHAIN_ADMIN_PRIVATE_KEY=
BLOCKCHAIN_REQUIRED=false



